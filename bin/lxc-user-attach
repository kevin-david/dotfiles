#!/usr/bin/env bash
# Attach directly to a Proxmox LXC as a guest user without SSH or su.

set -euo pipefail

CT_PATH="${CT_PATH:-/run/current-system/sw/bin:/run/wrappers/bin:/usr/bin:/bin}"
LXC_PATH="${LXC_PATH:-/var/lib/lxc}"
DEFAULT_USER="${ATTACH_USER:-${SUDO_USER:-${USER:-root}}}"
START_POLICY="${LXC_USER_ATTACH_START:-auto}"

if [ "${EUID:-$(id -u)}" -ne 0 ]; then
  exec sudo --preserve-env=ATTACH_USER,CT_PATH,LXC_PATH,LXC_USER_ATTACH_START -- "$0" "$@"
fi

usage(){
  cat <<EOF
Usage:
  lxc-user-attach HOSTNAME_OR_CTID [USER]
  lxc-user-attach HOSTNAME_OR_CTID [USER] -- COMMAND [ARG...]

Environment overrides:
  ATTACH_USER=$DEFAULT_USER
  CT_PATH=$CT_PATH
  LXC_PATH=$LXC_PATH
  LXC_USER_ATTACH_START=auto|ask|always|never

Examples:
  lxc-user-attach devbox-01
  lxc-user-attach 102 kevin
  lxc-user-attach 102 kevin -- /run/current-system/sw/bin/id
EOF
}

die(){
  echo "[error] $*" >&2
  exit 1
}

ct_hostname(){
  pct config "$1" 2>/dev/null | awk -F': ' '$1=="hostname"{print $2; exit}'
}

ctid_for_hostname(){
  local name="$1" id host match="" count=0

  while read -r id; do
    [ -n "$id" ] || continue
    host="$(ct_hostname "$id")"
    if [ "${host,,}" = "${name,,}" ]; then
      match="$id"
      count=$((count + 1))
    fi
  done < <(pct list 2>/dev/null | awk 'NR>1 {print $1}')

  if [ "$count" -gt 1 ]; then
    die "hostname $name matches multiple CTs"
  fi
  [ "$count" -eq 0 ] || printf '%s\n' "$match"
}

start_stopped_ct(){
  local ctid="$1" status="$2" answer

  case "${START_POLICY,,}" in
    always|yes|true|1)
      pct start "$ctid" || die "failed to start CT $ctid"
      return
      ;;
    never|no|false|0)
      die "CT $ctid is $status; start it first"
      ;;
    auto|"")
      if [ ! -t 0 ]; then
        die "CT $ctid is $status; start it first"
      fi
      ;;
    ask)
      ;;
    *)
      die "invalid LXC_USER_ATTACH_START=$START_POLICY (expected auto, ask, always, or never)"
      ;;
  esac

  printf 'CT %s is %s. Start it now? [Y/n] ' "$ctid" "$status" >&2
  IFS= read -r answer || answer=
  case "${answer,,}" in
    n|no)
      die "CT $ctid is $status"
      ;;
    *)
      pct start "$ctid" || die "failed to start CT $ctid"
      ;;
  esac
}

target="${1:-}"
if [ -z "$target" ] || [ "$target" = "-h" ] || [ "$target" = "--help" ]; then
  usage
  exit 0
fi
shift

user="$DEFAULT_USER"
if [ $# -gt 0 ] && [ "$1" != "--" ]; then
  user="$1"
  shift
fi

command_args=()
if [ $# -gt 0 ]; then
  if [ "$1" != "--" ]; then
    die "unknown argument: $1"
  fi
  shift
  command_args=("$@")
fi

if [[ "$target" =~ ^[0-9]+$ ]]; then
  ctid="$target"
else
  ctid="$(ctid_for_hostname "$target")"
  [ -n "$ctid" ] || die "no CT found with hostname: $target"
fi

if ! status_line="$(pct status "$ctid" 2>/dev/null)"; then
  die "CT does not exist: $ctid"
fi
status="$(printf '%s\n' "$status_line" | awk '{print $2}')"
if [ "$status" != running ]; then
  start_stopped_ct "$ctid" "$status"
  if ! status_line="$(pct status "$ctid" 2>/dev/null)"; then
    die "CT disappeared after start: $ctid"
  fi
  status="$(printf '%s\n' "$status_line" | awk '{print $2}')"
  [ "$status" = running ] || die "CT $ctid is $status after start"
fi

if ! passwd_entry="$(pct exec "$ctid" -- env PATH="$CT_PATH" getent passwd "$user")"; then
  die "user $user does not exist in CT $ctid"
fi
[ -n "$passwd_entry" ] || die "user $user does not exist in CT $ctid"

IFS=: read -r user_name _user_pass ct_uid ct_gid _gecos home_dir shell_path _rest <<< "$passwd_entry"
[ -n "$ct_uid" ] || die "could not read uid for $user in CT $ctid"
[ -n "$ct_gid" ] || die "could not read gid for $user in CT $ctid"
[ -n "$home_dir" ] || die "could not read home for $user in CT $ctid"
if [ -z "$shell_path" ]; then
  shell_path="/bin/sh"
fi

if [ "${#command_args[@]}" -eq 0 ]; then
  command_args=("$shell_path" -l)
fi

# NOTE: lxc-attach --uid/--gid does a bare setuid/setgid and never calls
# initgroups(), so supplementary groups (e.g. docker) are dropped and the
# user lands with only their primary group. Attach as root and switch
# identity inside the CT with setpriv --init-groups, which loads the full
# supplementary group list from the guest's /etc/group.
exec lxc-attach -P "$LXC_PATH" -n "$ctid" --clear-env \
  --set-var PATH="$CT_PATH" \
  --set-var USER="$user_name" \
  --set-var LOGNAME="$user_name" \
  --set-var HOME="$home_dir" \
  --set-var SHELL="$shell_path" \
  -- setpriv --reuid "$ct_uid" --regid "$ct_gid" --init-groups \
     "${command_args[@]}"
